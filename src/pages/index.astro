---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroDropZone from '../components/tools/HeroDropZone';
import DecorativeBlob from '../components/decorative/DecorativeBlob';
import WavyUnderline from '../components/decorative/WavyUnderline';
import ToolCard from '../components/ui/ToolCard';
import { pdfTools, imageTools } from '../lib/tools-config';
import { buildVideoSchema, buildOrganizationSchema } from '../lib/schema';
import { ShieldCheck, Zap, Shield, DollarSign } from 'lucide-react';

const YOUTUBE_VIDEO_ID = 'XUsEyKTrIwU';
const videoEmbedUrl = `https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}`;
const videoSchema = buildVideoSchema({
  title: 'Priva.TOOLS - Free Online PDF & Image Tools | 100% Private',
  description: 'Discover 10 free online tools to compress, merge, split PDFs and compress, resize, crop images. Everything runs in your browser with WebAssembly. Your files never leave your device.',
  thumbnailUrl: 'https://priva.tools/og-default.jpg',
  uploadDate: '2026-03-03',
  duration: 'PT1M15S',
  embedUrl: videoEmbedUrl,
});
const orgSchema = buildOrganizationSchema();
---

<BaseLayout title="Priva.TOOLS - Free Online PDF & Image Tools | 100% Private" description="Free online PDF and image tools. Compress, merge, split PDFs. Compress, resize, crop images. Remove backgrounds with AI. Everything runs in your browser, your files never leave your device." ogVideo={videoEmbedUrl}>
  <Header />

  <section class="relative min-h-[85vh] w-full overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 via-purple-500/10 to-pink-500/10"></div>
      <DecorativeBlob color="#6366f1" className="top-[10%] -left-[10%] w-[500px] h-[500px]" client:visible />
      <DecorativeBlob color="#ec4899" className="bottom-[10%] -right-[10%] w-[600px] h-[600px]" client:visible />
    </div>

    <div class="relative z-10 flex items-center justify-center min-h-[85vh] px-6 py-16">
      <div class="w-full max-w-5xl mx-auto text-center flex flex-col items-center gap-10">
        <div class="inline-flex items-center gap-3 px-8 py-3 rounded-full bg-white border-2 border-slate-900 shadow-[4px_4px_0px_0px_rgba(15,23,42,1)]">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
          </span>
          <span class="text-sm font-black text-slate-900 uppercase tracking-widest">100% Client-Side WASM</span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-black text-slate-900 leading-[1.15] tracking-tighter">
          Compress, merge, convert. <br class="hidden md:block" />
          <span class="relative inline-block">
            Your files stay
            <WavyUnderline client:visible />
          </span>{' '}
          in your browser.
        </h1>

        <HeroDropZone client:visible />

        <div class="flex items-center justify-center">
          <div class="flex items-center gap-4 px-10 py-5 bg-emerald-50 border-2 border-emerald-500 rounded-2xl text-emerald-800">
            <ShieldCheck className="text-emerald-500 shrink-0" size={32} strokeWidth={2.5} />
            <div class="text-left">
              <p class="text-xl font-black leading-tight">Nothing is uploaded. Ever.</p>
              <p class="text-sm font-bold opacity-80 uppercase tracking-wider">Privacy guaranteed by code</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="pdf-tools" class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mb-8">
      PDF Tools
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {pdfTools.map(tool => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <section id="image-tools" class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mb-8">
      Image Tools
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {imageTools.map(tool => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="p-6 rounded-2xl bg-indigo-50 border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-sm)]">
        <Shield size={32} className="text-indigo-500 mb-3" strokeWidth={2.5} />
        <h3 class="font-black text-slate-900 text-lg">100% Local</h3>
        <p class="text-sm text-slate-600 mt-2">Files are processed in your browser. Nothing leaves your device.</p>
      </div>
      <div class="p-6 rounded-2xl bg-amber-50 border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-sm)]">
        <Zap size={32} className="text-amber-500 mb-3" strokeWidth={2.5} />
        <h3 class="font-black text-slate-900 text-lg">Lightning Fast</h3>
        <p class="text-sm text-slate-600 mt-2">No upload, no download wait. Processing starts instantly.</p>
      </div>
      <div class="p-6 rounded-2xl bg-emerald-50 border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-sm)]">
        <ShieldCheck size={32} className="text-emerald-500 mb-3" strokeWidth={2.5} />
        <h3 class="font-black text-slate-900 text-lg">GDPR Native</h3>
        <p class="text-sm text-slate-600 mt-2">Zero server processing means zero data to protect. Privacy by design.</p>
      </div>
      <div class="p-6 rounded-2xl bg-rose-50 border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-sm)]">
        <DollarSign size={32} className="text-rose-500 mb-3" strokeWidth={2.5} />
        <h3 class="font-black text-slate-900 text-lg">Free, No Account</h3>
        <p class="text-sm text-slate-600 mt-2">All tools are free to use. No sign-up, no limits, no strings.</p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mb-8 text-center">
      See It In Action
    </h2>
    <div class="rounded-2xl border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-md)] overflow-hidden bg-slate-900 aspect-video">
      <iframe
        width="100%"
        height="100%"
        src={videoEmbedUrl}
        title="Priva.TOOLS - Free Online PDF & Image Tools"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        class="w-full h-full"
      ></iframe>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Priva.TOOLS",
    "url": "https://priva.tools",
    "description": "Free online PDF and image tools with 100% client-side processing. Your files never leave your browser.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://priva.tools/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
</BaseLayout>
