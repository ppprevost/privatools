---
// Static skeleton matching the compact DropZone shape.
// Shown while a client:only React component is loading.
// The React component removes it on mount via useEffect.
---
<style>
  /* hide the astro-island while the skeleton is still in the DOM */
  :global(#dropzone-skeleton ~ astro-island) {
    display: none;
  }
</style>

<div
  id="dropzone-skeleton"
  aria-hidden="true"
  class="relative overflow-hidden bg-white rounded-[var(--radius-card)] border-[4px] border-dashed border-slate-200 p-8 md:p-12"
>
  <div class="flex flex-col items-center justify-center text-center space-y-6 animate-pulse">
    <!-- icon placeholder -->
    <div class="w-20 h-20 rounded-full bg-slate-100"></div>
    <!-- title placeholder -->
    <div class="space-y-2 flex flex-col items-center">
      <div class="h-6 w-48 rounded-lg bg-slate-100"></div>
      <div class="h-4 w-32 rounded-lg bg-slate-100"></div>
    </div>
    <!-- button placeholder -->
    <div class="h-11 w-32 rounded-2xl bg-slate-100"></div>
  </div>
  <!-- same dot pattern as DropZone -->
  <div
    class="absolute top-0 left-0 w-full h-full opacity-[0.03] pointer-events-none"
    style="background-image: radial-gradient(#000 2px, transparent 2px); background-size: 24px 24px;"
  />
</div>
