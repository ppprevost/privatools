---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center gap-1.5 text-sm text-slate-500 font-bold">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span class="text-slate-300" aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-indigo-500 transition-colors">{item.label}</a>
        ) : (
          <span class="text-slate-900">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
